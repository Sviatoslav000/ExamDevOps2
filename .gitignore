# === Тимчасові файли та бінарники Terraform ===
# Ігноруємо всі папки .terraform незалежно від їхнього розташування
**/.terraform/
# Файл блокування (якщо ви працюєте один, його можна ігнорувати, 
# але для командної роботи іноді залишають. Краще ігнорувати для лаб.)
.terraform.lock.hcl

# === Секрети та ключі (КРИТИЧНО) ===
# Ваш специфічний файл ключа
terraformkey.json
# Загальні розширення для ключів
*.pem
*.key
*.pub
# Файли змінних, які зазвичай містять паролі/токени
*.tfvars
*.tfvars.json

# === Стан інфраструктури (State) ===
# Файли стану мають бути в хмарі (S3/GCS), а не в git
*.tfstate
*.tfstate.*

# === Специфічні папки за вашим запитом ===
# Повністю ігноруємо папку ansible
ansible/

# === Логи та тимчасові файли ===
*.log
crash.log
# Тимчасові файли редакторів
.vscode/
.idea/
.DS_Store
